# ─────────────────────────────────────────────────────────────────
# CrowdEase IoT Simulator — Konfigurasi
# ─────────────────────────────────────────────────────────────────
#
# Salin file ini menjadi .env, lalu isi nilai yang sebenarnya.
# Jangan commit file .env yang sudah berisi API key ke Git.

# URL backend Laravel. Tanpa trailing slash.
# Saat development di lokal: http://localhost:8000
# Saat dalam jaringan kampus: http://192.168.x.x:8000
CROWDEASE_BASE_URL=http://localhost:8000

# API key yang valid di tabel api_keys.
# API key dibuat oleh operator melalui dashboard admin:
#   /admin/api-keys → klik "Buat API Key Baru"
# Nilai key yang sebenarnya hanya muncul SEKALI saat dibuat — wajib dicatat.
CROWDEASE_API_KEY=ce_iot_PASTE_API_KEY_DI_SINI
