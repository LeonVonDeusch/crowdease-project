# ─────────────────────────────────────────────────────────────────
# CrowdEase Project — Shared Environment Variables
# ─────────────────────────────────────────────────────────────────
#
# Salin file ini menjadi .env, isi dengan nilai yang sebenarnya.
# File ini opsional — masing-masing komponen (backend, simulator)
# punya .env sendiri di subfoldernya.
#
# Yang dimuat di sini biasanya hanya variabel yang perlu di-share
# antar service (mis. saat docker-compose run semua bersama).

# Database
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=crowdease
DB_USERNAME=crowdease
DB_PASSWORD=crowdease_secret

# IoT API key — dibuat oleh operator via dashboard, lalu paste di sini
# untuk digunakan oleh simulator saat docker-compose up
CROWDEASE_API_KEY=
